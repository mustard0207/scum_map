<!-- 首页 - 功能入口 -->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title">SCUM游戏工具箱</text>
    </view>
  </view>

  <!-- 主内容 -->
  <view class="main">
    <!-- 上方内容 -->
    <view class="main-top" style="padding-top: {{statusBarHeight + 44}}px;">
      <!-- Logo 区域 -->
      <view class="logo-section">
        <image class="logo-img" src="/assets/logo.png" mode="aspectFit" />
        <text class="logo-title">SCUM游戏工具箱</text>
      </view>

      <!-- 功能入口 -->
      <view class="features">
        <!-- 地图功能 -->
        <view class="feature-card" bindtap="goToMap">
          <view class="feature-icon-area">
            <text class="feature-glyph">🗺️</text>
          </view>
          <view class="feature-info">
            <text class="feature-title">SCUM游戏地图</text>
            <text class="feature-desc">全图资源点位速查，轻松标记个人物资与载具状态。</text>
          </view>
          <view class="feature-arrow">›</view>
        </view>

        <!-- 地堡解密工具 -->
        <view class="feature-card" bindtap="goToBunker">
          <view class="feature-icon-area">
            <text class="feature-glyph">🧮</text>
          </view>
          <view class="feature-info">
            <text class="feature-title">地堡工具</text>
            <text class="feature-desc">废弃地堡计算器、保险丝计时器等</text>
          </view>
          <view class="feature-arrow">›</view>
        </view>

        <!-- 武器查询工具 -->
        <view class="feature-card" bindtap="goToWeapons">
          <view class="feature-icon-area">
            <text class="feature-glyph">⚔️</text>
          </view>
          <view class="feature-info">
            <text class="feature-title">武器数据手册</text>
            <text class="feature-desc">全图鉴武器数据一览，轻松查询可用弹药与配件配置。</text>
          </view>
          <view class="feature-arrow">›</view>
        </view>

        <!-- 狩猎助手 -->
        <view class="feature-card" bindtap="goToHunting">
          <view class="feature-icon-area">
            <text class="feature-glyph">🐻</text>
          </view>
          <view class="feature-info">
            <text class="feature-title">狩猎助手</text>
            <text class="feature-desc">快速找到动物刷新点，提高狩猎效率。</text>
          </view>
          <view class="feature-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- 底部内容 -->
    <view class="main-bottom">
      <!-- 免责声明 -->
      <view class="disclaimer">
        <text class="disclaimer-text">玩家自制工具，非官方出品。数据自己整理，仅供参考。</text>
      </view>
      <!-- 版本信息 -->
      <view class="version-info">
        <text class="version-text">v{{version}}</text>
      </view>
    </view>
  </view>
</view>
