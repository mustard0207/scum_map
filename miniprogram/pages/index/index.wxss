/* 首页样式 — 生存终端主题 */
.page {
  min-height: 100vh;
  background: #121008;
}

.main {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.main-top {
  flex: 1;
}

.main-bottom {
  flex-shrink: 0;
  padding-bottom: 20px;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #1C1A10;
  border-bottom: 1px solid #3A3520;
}

.nav-content {
  position: relative;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title-group {
  position: relative;
  display: flex;
  align-items: center;
}

.nav-logo {
  position: absolute;
  right: 100%;
  top: 50%;
  transform: translateY(-50%);
  width: 50px;
  height: 50px;
  border-radius: 11px;
  margin-right: 14px;
}

.nav-title {
  color: #D4C8A0;
  font-size: 17px;
  font-weight: 600;
  letter-spacing: 1px;
}

/* 副标题区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1px 0 25px;
}

.logo-desc {
  font-size: 14px;
  color: #7A6B4A;
}

.logo-subtitle {
  font-size: 13px;
  color: #A39B82;
  margin-bottom: 8px;
}

.logo-version {
  font-size: 11px;
  color: #7A6B4A;
  background: rgba(122, 107, 74, 0.15);
  padding: 2px 8px;
  border-radius: 10px;
}

/* 功能入口 */
.features {
  padding: 0 15px;
  max-width: 600px;
  margin: 0 auto;
  box-sizing: border-box;
}

.feature-card {
  position: relative;
  display: flex;
  align-items: center;
  background: #1C1A10;
  border-radius: 6px;
  padding: 18px 15px;
  margin-bottom: 16px;
  border: 1px solid #3A3520;
  transition: all 0.2s;
}

.feature-tag {
  position: absolute;
  top: -8px;
  left: 12px;
  padding: 1px 6px;
  font-size: 10px;
  border-radius: 3px;
  font-weight: 500;
  z-index: 2;
}

.feature-tag-core {
  background: #2D2816;
  color: #FFB000;
  border: 1px solid #FFB000;
}

.feature-tag-tactical {
  background: #1E281F;
  color: #67C23A;
  border: 1px solid #345B2C;
}

.feature-tag-aux {
  background: #262626;
  color: #9E9E9E;
  border: 1px solid #424242;
}

.feature-card:active {
  border-color: #FFB000;
  background: #24210F;
}

.feature-disabled {
  opacity: 0.5;
}

.feature-icon-area {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 176, 0, 0.1);
  border-radius: 8px;
  margin-right: 12px;
  flex-shrink: 0;
}

.feature-glyph {
  font-size: 24px;
  color: #FFB000;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 17px;
  font-weight: 600;
  color: #D4C8A0;
  margin-bottom: 3px;
}

.feature-desc {
  font-size: 13px;
  color: #7A6B4A;
}

.feature-arrow {
  font-size: 24px;
  color: #FFB000;
  font-weight: 300;
  margin-left: 5px;
}

.feature-badge {
  font-size: 10px;
  color: #E85D3A;
  background: rgba(232, 93, 58, 0.12);
  padding: 3px 8px;
  border-radius: 10px;
  flex-shrink: 0;
}

/* 底部工具栏 */
.bottom-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 20px;
}

.bottom-item {
  display: flex;
  align-items: center;
  color: #7A6B4A;
  font-size: 12px;
  white-space: nowrap;
}

.bottom-icon {
  font-size: 14px;
  margin-right: 4px;
  opacity: 0.8;
}
