/* 首页样式 — 生存终端主题 */
.page {
  min-height: 100vh;
  background: #121008;
}

.main {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.main-top {
  flex: 1;
}

.main-bottom {
  flex-shrink: 0;
  padding-bottom: 40rpx;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #1C1A10;
  border-bottom: 1rpx solid #3A3520;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  color: #D4C8A0;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 80rpx;
}

.logo-img {
  width: 200rpx;
  height: 109rpx;
  margin-bottom: 24rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #D4C8A0;
  margin-bottom: 10rpx;
  letter-spacing: 4rpx;
}

.logo-desc {
  font-size: 28rpx;
  color: #7A6B4A;
}

.logo-subtitle {
  font-size: 26rpx;
  color: #A39B82;
  margin-bottom: 16rpx;
}

.logo-version {
  font-size: 22rpx;
  color: #7A6B4A;
  background: rgba(122, 107, 74, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 功能入口 */
.features {
  padding: 0 30rpx;
}

.feature-card {
  position: relative;
  display: flex;
  align-items: center;
  background: #1C1A10;
  border-radius: 12rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #3A3520;
  transition: all 0.2s;
}

.feature-tag {
  position: absolute;
  top: -16rpx;
  left: 24rpx;
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  border-radius: 6rpx;
  font-weight: 500;
  z-index: 2;
}

.feature-tag-core {
  background: #2D2816;
  color: #FFB000;
  border: 1rpx solid #FFB000;
}

.feature-tag-tactical {
  background: #1E281F;
  color: #67C23A;
  border: 1rpx solid #345B2C;
}

.feature-tag-aux {
  background: #262626;
  color: #9E9E9E;
  border: 1rpx solid #424242;
}

.feature-card:active {
  border-color: #FFB000;
  background: #24210F;
}

.feature-disabled {
  opacity: 0.5;
}

.feature-icon-area {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 176, 0, 0.1);
  border-radius: 16rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-glyph {
  font-size: 48rpx;
  color: #FFB000;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #D4C8A0;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #7A6B4A;
}

.feature-arrow {
  font-size: 48rpx;
  color: #FFB000;
  font-weight: 300;
  margin-left: 10rpx;
}

.feature-badge {
  font-size: 20rpx;
  color: #E85D3A;
  background: rgba(232, 93, 58, 0.12);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* 底部工具栏 */
.bottom-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 40rpx;
}

.bottom-item {
  display: flex;
  align-items: center;
  color: #7A6B4A;
  font-size: 24rpx;
  white-space: nowrap;
}

.bottom-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  opacity: 0.8;
}
