/* 瓦片地图组件样式 — touch 手势版 */
:host {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
}

.map-viewport {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #121008;
  position: relative;
}

.map-canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 1280px;
  height: 1280px;
  will-change: transform;
  overflow: hidden;
}

.map-tile {
  display: block;
  position: absolute;
}

.full-map {
  display: block;
  width: 100%;
  height: 100%;
}

/* 标记 — 水滴形态，尖角指向坐标点 */
.map-marker {
  position: absolute;
  /* 不使用 transform-origin，通过精确 translate 将尖角(左下角)定位到 left/top 坐标 */
  /* 计算：边框盒 24×24，中心 (12,12)，尖角 (0,24) */
  /* rotate(-45deg) 围绕默认中心(12,12)旋转后，尖角偏移 (12√2, 12√2) ≈ (17, 17) */
  /* 再 translate(-12, -12-12√2) = (-12, -29) 将尖角归位到原点 */
  transform: translate(-12px, -29px) rotate(-45deg);
  z-index: 20;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50% 50% 50% 0;
  background: rgba(30, 30, 30, 0.85);
  border: 2px solid #FFFFFF;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
}

.marker-circle {
  width: 12px;
  height: 12px;
  border: 2px solid #FFB000;
  border-radius: 50%;
  background: rgba(255, 176, 0, 0.15);
  box-shadow: 0 0 4px rgba(255, 176, 0, 0.6);
}

.marker-emoji {
  font-size: 13px;
  line-height: 1;
  text-shadow: 0 0 2px rgba(0, 0, 0, 0.6);
  transform: rotate(45deg);
}

/* 有底色的标记：覆盖默认背景为类型颜色 */
.marker-typed {
  background: #6BBF59;
}

/* 静态的残缺车辆提醒（废土暗橙色，不闪烁） */
.marker-incomplete {
  background: #C85A17 !important;
  border-color: #FF5500 !important;
  box-shadow: inset 0 0 8px rgba(0,0,0,0.4), 0 0 4px rgba(255, 85, 0, 0.6) !important;
}

/* 过期警告：红白缓慢闪烁 (定义在后面以保证优先级高于 incomplete) */
.marker-expiring {
  border-color: #FF3333;
  box-shadow: 0 0 8px rgba(255, 50, 50, 0.8);
  animation: marker-pulse 1.5s ease-in-out infinite alternate;
  animation-delay: var(--pulse-delay, 0s);
}

@keyframes marker-pulse {
  from {
    border-color: #FF3333;
    box-shadow: 0 0 8px rgba(255, 50, 50, 0.8);
  }
  to {
    border-color: #FFFFFF;
    box-shadow: 0 0 4px rgba(255, 255, 255, 0.4);
  }
}

/* 地名文字标签 */
.map-label {
  position: absolute;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 15;
  white-space: nowrap;
}

.label-text {
  font-size: 11px;
  color: #FFFFFF;
  text-shadow:
    -1px 0 0 rgba(0, 0, 0, 0.9),
     1px 0 0 rgba(0, 0, 0, 0.9),
    0 -1px 0 rgba(0, 0, 0, 0.9),
    0  1px 0 rgba(0, 0, 0, 0.9),
    0 0 3px rgba(0, 0, 0, 0.6);
  letter-spacing: 0.5px;
}

/* 安全区圆圈 */
.safe-zone {
  position: absolute;
  box-sizing: border-box;
  border-radius: 50%;
  border: 2px solid rgba(107, 191, 89, 0.6);
  background: rgba(107, 191, 89, 0.12);
  pointer-events: none;
  z-index: 10;
}

/* 区域网格叠加层 */
.grid-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
  z-index: 5;
}

.grid-line {
  position: absolute;
  background: rgba(255, 255, 255, 0.2);
}

.grid-line-h {
  height: 1.5px;
}

.grid-line-v {
  width: 1.5px;
}

.grid-label {
  position: absolute;
  font-size: 16px;
  font-weight: normal;
  color: rgba(255, 255, 255, 1);
  pointer-events: none;
  text-shadow:
    -1px 0 0 rgba(0, 0, 0, 0.8),
     1px 0 0 rgba(0, 0, 0, 0.8),
    0 -1px 0 rgba(0, 0, 0, 0.8),
    0  1px 0 rgba(0, 0, 0, 0.8);
  white-space: nowrap;
}
