/* 瓦片地图组件样式 — touch 手势版 */
:host {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
}

.map-viewport {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #121008;
  position: relative;
}

.map-canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 1280px;
  height: 1280px;
  will-change: transform;
  overflow: hidden;
}

.map-tile {
  display: block;
  position: absolute;
}

.full-map {
  display: block;
  width: 100%;
  height: 100%;
}

/* 标记 */
.map-marker {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 20;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.marker-circle {
  width: 12px;
  height: 12px;
  border: 2px solid #FFB000;
  border-radius: 50%;
  background: rgba(255, 176, 0, 0.15);
  box-shadow: 0 0 4px rgba(255, 176, 0, 0.6);
}

.marker-emoji {
  font-size: 12px;
  line-height: 1;
  text-shadow: 0 0 2px rgba(0, 0, 0, 0.6);
}

.marker-typed {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  box-shadow: 0 0 4px rgba(0, 0, 0, 0.4);
}

/* 区域网格叠加层 */
.grid-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
  z-index: 5;
}

.grid-line {
  position: absolute;
  background: rgba(255, 255, 255, 0.2);
}

.grid-line-h {
  height: 1.5px;
}

.grid-line-v {
  width: 1.5px;
}

.grid-label {
  position: absolute;
  font-size: 16px;
  font-weight: bold;
  color: rgba(255, 255, 255, 1);
  pointer-events: none;
  text-shadow:
    -1px 0 0 rgba(0, 0, 0, 0.8),
     1px 0 0 rgba(0, 0, 0, 0.8),
    0 -1px 0 rgba(0, 0, 0, 0.8),
    0  1px 0 rgba(0, 0, 0, 0.8);
  white-space: nowrap;
}
