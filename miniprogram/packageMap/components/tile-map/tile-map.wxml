<!-- 全地图底图组件 (touch 手势版) -->
<wxs module="gestures" src="./gestures.wxs"></wxs>
<view
  class="map-viewport"
  style="width:{{_vw}}px;height:{{_vh}}px;"
  prop="{{wxsState}}"
  change:prop="{{gestures.propChange}}"
  catchtouchstart="{{gestures.touchstart}}"
  catchtouchmove="{{gestures.touchmove}}"
  catchtouchend="{{gestures.touchend}}"
>
  <view class="map-canvas">
    <!-- Z2 底图（始终渲染，作为兜底背景） -->
    <image
      class="full-map"
      src="{{fullMapSrc}}"
      mode="scaleToFill"
      webp="{{true}}"
      binderror="onImageError"
      bindload="onImageLoad"
    />
    <!-- Z3/Z4 瓦片网格（主层，Z3 或 Z4 时显示，Z6 时 Z4 作为兜底） -->
    <image
      wx:for="{{visibleTiles}}"
      wx:key="id"
      class="map-tile"
      src="{{item.src}}"
      data-id="{{item.id}}"
      data-lx="{{item.lx}}"
      data-ly="{{item.ly}}"
      data-lsize="{{item.lsize}}"
      bindload="onTileLoad"
      binderror="onTileError"
    />
    <!-- Z6 瓦片网格（叠加层，仅 Z6 激活时显示，叠在 Z4 上面） -->
    <image
      wx:for="{{visibleTilesOverlay}}"
      wx:key="id"
      class="map-tile"
      src="{{item.src}}"
      data-id="{{item.id}}"
      data-lx="{{item.lx}}"
      data-ly="{{item.ly}}"
      data-lsize="{{item.lsize}}"
      bindload="onTileLoad"
      binderror="onTileError"
    />
  </view>

  <!-- 区域网格叠加层（pointer-events: none，不阻挡手势） -->
  <view class="grid-overlay">
    <view wx:for="{{gridLinesH}}" wx:key="id"
      class="grid-line grid-line-h"
      data-ly="{{item.ly}}" />
    <view wx:for="{{gridLinesV}}" wx:key="id"
      class="grid-line grid-line-v"
      data-lx="{{item.lx}}" />
    <view wx:for="{{gridLabels}}" wx:key="id"
      class="grid-label"
      data-lx="{{item.lx}}"
      data-ly="{{item.ly}}">
      {{item.text}}
    </view>
  </view>
</view>

<!-- 标记列表（放在 map-viewport 外面，避免被 catchtouchstart 拦截） -->
<view
  wx:for="{{markersOnScreen}}"
  wx:key="id"
  class="map-marker"
  data-id="{{item.id}}"
  data-px="{{item.px}}"
  data-py="{{item.py}}"
  bindtap="onMarkerTap"
>
  <text class="marker-emoji">{{item.emoji || '📌'}}</text>
</view>
