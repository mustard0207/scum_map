var state = {
  minY: 0,
  maxY: 0,
  currentY: 0,
  isExpanded: false,
  initialized: false
}

var lastTouchY = 0
var animId = 0

function init(newVal, oldVal, ownerInstance, instance) {
  if (newVal && typeof newVal.initialTranslateY === 'number') {
    state.minY = 0 // 完全展开时，偏移量为 0
    state.maxY = newVal.initialTranslateY // 折叠时，偏移量最大，藏在屏幕下方
    
    // 如果收到强制折叠的信号 (点击了遮罩层)
    if (newVal.collapseSignal !== undefined && oldVal && newVal.collapseSignal !== oldVal.collapseSignal) {
      animateTo(state.maxY, ownerInstance, instance, function() {
        state.isExpanded = false
        ownerInstance.callMethod('onPanelStateChange', { isExpanded: false })
      })
      return
    }
    
    // 如果收到强制展开的信号 (点击了某只动物，或者点击了探测按钮)
    if (newVal.expandSignal !== undefined && oldVal && newVal.expandSignal !== oldVal.expandSignal) {
      animateTo(state.minY, ownerInstance, instance, function() {
        state.isExpanded = true
        ownerInstance.callMethod('onPanelStateChange', { isExpanded: true })
      })
      return
    }
    
    // 如果是首次初始化，立即设定位置
    if (!state.initialized) {
      state.currentY = state.maxY
      state.isExpanded = false
      state.initialized = true
      instance.setStyle({
        transform: 'translateY(' + state.currentY + 'px)'
      })
    }
  }
}

function touchstart(e, ownerInstance) {
  animId++ // 打断任何正在运行的吸附动画
  var touches = e.touches
  if (touches.length === 1) {
    lastTouchY = touches[0].clientY
  }
}

function touchmove(e, ownerInstance) {
  var instance = ownerInstance.selectComponent('.console-panel')
  if (!instance) return
  var touches = e.touches
  if (touches.length === 1) {
    var clientY = touches[0].clientY
    var deltaY = clientY - lastTouchY
    lastTouchY = clientY
    
    state.currentY += deltaY
    
    // 增加一点橡皮筋阻力效果（超出边界时）
    if (state.currentY < state.minY) {
      state.currentY = state.minY - Math.sqrt(state.minY - state.currentY) * 2
    } else if (state.currentY > state.maxY) {
      state.currentY = state.maxY + Math.sqrt(state.currentY - state.maxY) * 2
    }
    
    instance.setStyle({
      transform: 'translateY(' + state.currentY + 'px)',
      transition: 'none'
    })
  }
}

function touchend(e, ownerInstance) {
  var instance = ownerInstance.selectComponent('.console-panel')
  if (!instance) return
  var threshold = (state.maxY - state.minY) / 4 // 拖动超过 1/4 则判定为切换状态
  var targetY = state.currentY
  var nextIsExpanded = state.isExpanded
  
  if (state.isExpanded) {
    // 当前是展开状态，用户往下滑
    if (state.currentY > state.minY + threshold) {
      targetY = state.maxY
      nextIsExpanded = false
    } else {
      targetY = state.minY
    }
  } else {
    // 当前是折叠状态，用户往上滑
    if (state.currentY < state.maxY - threshold) {
      targetY = state.minY
      nextIsExpanded = true
    } else {
      targetY = state.maxY
    }
  }
  
  // 执行吸附动画
  animateTo(targetY, ownerInstance, instance, function() {
    if (nextIsExpanded !== state.isExpanded) {
      state.isExpanded = nextIsExpanded
      // 通知 JS 层更新状态，以切换 scroll-y 和遮罩层
      ownerInstance.callMethod('onPanelStateChange', { isExpanded: state.isExpanded })
    }
  })
}

function animateTo(targetY, ownerInstance, instance, callback) {
  animId++
  var currentAnimId = animId
  var DURATION = 300 // ms
  var startY = state.currentY
  var startTime = getDate().getTime()
  
  function step() {
    if (currentAnimId !== animId) return
    
    var elapsed = getDate().getTime() - startTime
    var t = Math.min(1, Math.max(0, elapsed / DURATION))
    // 缓动算法 ease-out
    var ease = 1 - Math.pow(1 - t, 3)
    
    state.currentY = startY + (targetY - startY) * ease
    
    instance.setStyle({
      transform: 'translateY(' + state.currentY + 'px)',
      transition: 'none'
    })
    
    if (t < 1) {
      ownerInstance.requestAnimationFrame(step)
    } else {
      if (callback) callback()
    }
  }
  
  ownerInstance.requestAnimationFrame(step)
}

function togglePanel(e, ownerInstance) {
  var instance = ownerInstance.selectComponent('.console-panel')
  if (!instance) return
  
  var targetY = state.isExpanded ? state.maxY : state.minY
  var nextIsExpanded = !state.isExpanded
  
  animateTo(targetY, ownerInstance, instance, function() {
    if (nextIsExpanded !== state.isExpanded) {
      state.isExpanded = nextIsExpanded
      ownerInstance.callMethod('onPanelStateChange', { isExpanded: state.isExpanded })
    }
  })
}

module.exports = {
  init: init,
  touchstart: touchstart,
  touchmove: touchmove,
  touchend: touchend,
  togglePanel: togglePanel
}
