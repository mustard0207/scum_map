<!-- 地图页 -->
<view class="map-page">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">‹</view>
      <text class="nav-title">SCUM游戏地图</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 地图区域 -->
  <view class="map-area" style="top: {{statusBarHeight + 44}}px; bottom: {{bottomBarHeight}}px;" bindtap="onMapAreaTap">
    <tile-map id="tileMap" markers="{{markers}}" bindmarkertap="onMarkerTap" bindgestureend="onGestureEnd" bindmapready="onMapReady" />
  </view>

  <!-- 坐标显示（光标处的实时坐标） -->
  <view class="coord-panel" style="bottom: {{bottomBarHeight + 20 + (showSaveBanner ? 40 : 0)}}px;">
    <text class="coord-text">X: {{coordLng}}  Y: {{coordLat}}</text>
  </view>

  <!-- 十字光标（始终固定在屏幕正中央） -->
  <view class="crosshair">
    <view class="crosshair-h"></view>
    <view class="crosshair-v"></view>
    <view class="crosshair-dot"></view>
  </view>

  <!-- 缩放拖拉条（右侧，鼠标/手指拖拉放大缩小） -->
  <view class="zoom-slider"
    style="bottom: {{bottomBarHeight + 90 + (showSaveBanner ? 40 : 0)}}px;"
    catchtouchstart="onZoomSliderStart"
    catchtouchmove="onZoomSliderMove"
    catchtouchend="onZoomSliderEnd"
  >
    <view class="zoom-slider-track">
      <view class="zoom-slider-fill" style="height: {{zoomSliderPercent}}%;"></view>
    </view>
    <view class="zoom-slider-thumb" style="bottom: {{zoomSliderPercent}}%;"></view>
    <text class="zoom-slider-label">+</text>
    <text class="zoom-slider-label zoom-slider-label-bottom">−</text>
  </view>

  <!-- 回到全局视角按钮 -->
  <view class="reset-view-btn" bindtap="resetMapView" style="bottom: {{bottomBarHeight + 20 + (showSaveBanner ? 40 : 0)}}px;">
    <text class="reset-view-icon">⊙</text>
  </view>

  <!-- 信息窗口（点击标记后显示） -->
  <view class="info-window-mask" wx:if="{{showInfoWindow}}" bindtap="closeInfoWindow">
    <view class="info-window" catchtap="noop">
      <view class="info-window-header">
        <view class="info-window-title-area">
          <text class="info-window-icon">◆</text>
          <view class="info-window-title-wrap">
            <text class="info-window-title">{{selectedMarker.name || '自定义标记'}}</text>
            <text class="info-window-subtitle" wx:if="{{selectedMarker.src === 'poi'}}">{{poiCatName}}</text>
            <text class="info-window-subtitle" wx:elif="{{selectedMarker.type}}">{{markerTypes[selectedMarker.type].label}}</text>
            <text class="info-window-subtitle" wx:else>标记 #{{selectedMarkerIndex + 1}}</text>
          </view>
        </view>
        <view class="info-window-close" bindtap="closeInfoWindow">✕</view>
      </view>
      <view class="info-window-body">
        <view class="info-window-coord-row">
          <text class="info-window-coord-label">X</text>
          <text class="info-window-coord-label">Y</text>
        </view>
        <view class="info-window-coord-row">
          <text class="info-window-coord-value">{{selectedMarker.lng}}</text>
          <text class="info-window-coord-value">{{selectedMarker.lat}}</text>
        </view>
      </view>
      <!-- 过期信息（仅自定义标记） -->
      <view class="info-window-expiry" wx:if="{{selectedMarker.src !== 'poi' && selectedMarker.createdAt}}">
        <view class="expiry-row">
          <text class="expiry-label">放置时间</text>
          <picker mode="date" value="{{markerCreatedAtDate}}" bindchange="onCreatedAtDateChange">
            <text class="expiry-value expiry-editable">{{markerCreatedAtText}}</text>
          </picker>
        </view>
        <view class="expiry-row" wx:if="{{selectedMarkerExpiryDays > 0}}">
          <text class="expiry-label">剩余时间</text>
          <text class="expiry-value {{selectedMarkerRemainingDays < markerWarnDays ? 'expiry-warning' : ''}}">{{markerRemainingDaysText}}</text>
        </view>
        <view class="expiry-row" wx:elif="{{selectedMarkerExpiryDays === 0}}">
          <text class="expiry-label">有效期</text>
          <text class="expiry-value expiry-safe">永不过期</text>
        </view>
      </view>
      <view class="info-window-type-selector" wx:if="{{selectedMarker.src !== 'poi'}}">
        <view
          wx:for="{{markerTypes}}"
          wx:for-index="typeKey"
          wx:for-item="typeItem"
          wx:key="*this"
          class="type-btn {{selectedMarker.type === typeKey ? 'type-btn-active' : ''}}"
          style="{{selectedMarker.type === typeKey ? 'background:' + typeItem.color + ';color:#fff' : ''}}"
          data-type="{{typeKey}}"
          catchtap="setMarkerType"
        >{{typeItem.emoji}} {{typeItem.label}}</view>
        <view class="type-btn expiry-setting-btn" catchtap="showExpirySettings">⚙️ 时效</view>
      </view>
      <view class="info-window-actions">
        <block wx:if="{{selectedMarker.src === 'poi'}}">
          <view class="info-window-btn copy" bindtap="copyCoord">📋 复制</view>
          <button class="info-window-btn share" open-type="share">↗ 分享</button>
        </block>
        <block wx:else>
          <view class="info-window-btn delete" bindtap="deleteMarker">🗑 删除</view>
          <view class="info-window-btn maintain" bindtap="maintainMarker">🔄 刷新有效期</view>
          <button class="info-window-btn share" open-type="share">↗ 分享</button>
        </block>
      </view>
    </view>
  </view>

  <!-- 过期天数设置弹窗 -->
  <view class="expiry-settings-mask" wx:if="{{showExpirySettings}}" catchtap="hideExpirySettings">
    <view class="expiry-settings-dialog" catchtap="noop">
      <view class="expiry-settings-title">过期天数设置</view>
      <view class="expiry-settings-hint">设为 0 表示永不过期</view>
      <view class="expiry-settings-item">
        <text class="expiry-settings-label">📌 无类型</text>
        <input class="expiry-settings-input" type="number" value="{{tempExpiryDays['']}}" bindinput="onExpiryDaysInput" data-type="" />
        <text class="expiry-settings-unit">天</text>
      </view>
      <view class="expiry-settings-item" wx:for="{{markerTypes}}" wx:for-index="typeKey" wx:for-item="typeItem" wx:key="typeKey">
        <text class="expiry-settings-label">{{typeItem.emoji}} {{typeItem.label}}</text>
        <input class="expiry-settings-input" type="number" value="{{tempExpiryDays[typeKey]}}" bindinput="onExpiryDaysInput" data-type="{{typeKey}}" />
        <text class="expiry-settings-unit">天</text>
      </view>
      <view class="expiry-settings-divider"></view>
      <view class="expiry-settings-item">
        <text class="expiry-settings-label">⚠️ 最小提醒天数</text>
        <input class="expiry-settings-input" type="number" value="{{tempWarnDays}}" bindinput="onWarnDaysInput" />
        <text class="expiry-settings-unit">天</text>
      </view>
      <view class="expiry-settings-actions">
        <view class="expiry-settings-btn cancel" catchtap="hideExpirySettings">取消</view>
        <view class="expiry-settings-btn confirm" catchtap="saveExpirySettings">确定</view>
      </view>
    </view>
  </view>

  <!-- 坐标输入弹窗 -->
  <view class="coord-input-mask" wx:if="{{showCoordInput}}" bindtap="hideCoordInput">
    <view class="coord-input-dialog" catchtap="noop">
      <view class="coord-input-title">跳转到坐标</view>
      <view class="coord-input-hint">将游戏内地图的坐标粘贴到此处，即可在离线地图上标记该位置，方便路线规划与点位记录。</view>
      <input
        class="coord-input-field"
        placeholder="粘贴游戏坐标"
        value="{{coordInputValue}}"
        bindinput="onCoordInputChange"
        auto-focus
      />
      <view class="coord-input-actions">
        <view class="coord-input-btn cancel" bindtap="hideCoordInput">取消</view>
        <view class="coord-input-btn confirm" bindtap="jumpToCoord">跳转</view>
      </view>
    </view>
  </view>

  <!-- 分享内容提示条 -->
  <view class="save-banner" wx:if="{{showSaveBanner}}" style="bottom: {{bottomBarHeight}}px;">
    <text class="save-banner-text">📌 正在查看分享内容</text>
    <view class="save-banner-btn" catchtap="saveToLocal">保存到本地</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-bottom" id="bottomBar">
    <view class="bar-btn" bindtap="showCoordInput">
      <text class="bar-icon">⊕</text>
      <text class="bar-label">输入</text>
    </view>
    <view class="bar-btn" bindtap="placeMarker">
      <text class="bar-icon">◆</text>
      <text class="bar-label">选点</text>
    </view>
    <button class="bar-btn" open-type="share">
      <text class="bar-icon">↗</text>
      <text class="bar-label">分享</text>
    </button>
    <view class="bar-btn" bindtap="showDataDrawer">
      <text class="bar-icon">⇅</text>
      <text class="bar-label">管理</text>
    </view>
    <view class="bar-btn" bindtap="onFilterTap">
      <text class="bar-icon">☰</text>
      <text class="bar-label">筛选</text>
    </view>
  </view>

  <!-- 备份抽屉 -->
  <view class="data-drawer-mask" wx:if="{{showDataDrawer}}" bindtap="hideDataDrawer">
    <view class="data-drawer" catchtap="noop">
      <view class="data-drawer-item" bindtap="onDrawerImport">
        <view class="data-drawer-accent"></view>
        <view class="data-drawer-text">
          <text class="data-drawer-title">导入自定义标记</text>
          <text class="data-drawer-desc">粘贴代码恢复标记点</text>
        </view>
      </view>
      <view class="data-drawer-item" bindtap="onDrawerExport">
        <view class="data-drawer-accent"></view>
        <view class="data-drawer-text">
          <text class="data-drawer-title">导出自定义标记</text>
          <text class="data-drawer-desc">复制代码到剪贴板</text>
        </view>
      </view>
      <view class="data-drawer-item data-drawer-danger" bindtap="onDrawerClear">
        <view class="data-drawer-accent"></view>
        <view class="data-drawer-text">
          <text class="data-drawer-title">清空所有标记</text>
          <text class="data-drawer-desc">删除全部自定义标记</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 导入弹窗 -->
  <view class="import-mask" wx:if="{{showImportDialog}}" bindtap="hideImportDialog">
    <view class="import-dialog" catchtap="noop">
      <view class="import-title">导入标记</view>
      <view class="import-hint">粘贴导出的标记代码</view>
      <textarea
        class="import-field"
        placeholder="粘贴 SCUM# 开头的代码"
        value="{{importInputValue}}"
        bindinput="onImportInputChange"
        auto-focus
        maxlength="9999"
      />
      <view class="import-actions">
        <view class="import-btn cancel" bindtap="hideImportDialog">取消</view>
        <view class="import-btn confirm" bindtap="importMarkers">导入</view>
      </view>
    </view>
  </view>

  <!-- POI 筛选面板 -->
  <view class="filter-panel-mask" wx:if="{{showFilterPanel}}">
    <view class="filter-panel-mask-tap" bindtap="closeFilterPanel"></view>
    <view class="filter-panel" catchtap="noop">
      <view class="filter-header" catchtap="noop">
        <text class="filter-title">地点筛选</text>
        <view class="filter-reset" catchtap="resetPoiFilter">清除筛选</view>
        <view class="filter-close" catchtap="closeFilterPanel">✕</view>
      </view>
      <view class="filter-body" catchtap="noop">
        <!-- 精简模式 -->
        <view wx:if="{{!filterFullMode}}">
          <!-- 自定义标记大类 -->
          <view class="filter-group">
            <view class="filter-group-header" catchtap="toggleGroup" data-group="_custom">
              <text class="filter-group-icon">📌</text>
              <text class="filter-group-name">自定义标记</text>
              <text class="filter-group-count">{{sectionSelectedCounts['_custom'] || 0}}/4</text>
              <view class="filter-toggle {{showUserMarkers ? 'filter-toggle-on' : ''}}" catchtap="toggleShowUserMarkers">
                <view class="filter-toggle-thumb"></view>
              </view>
            </view>
            <view class="filter-subs" wx:if="{{expandedGroups['_custom']}}">
              <view class="filter-sub" wx:for="{{userMarkerFilterTypes}}" wx:for-item="sub" wx:key="id">
                <text class="filter-sub-name">{{sub.emoji}} {{sub.cnName}}</text>
                <text class="filter-sub-count">{{userMarkerTypeCounts[sub.id] || 0}}</text>
                <view
                  class="filter-toggle {{activeUserMarkerMap[sub.id] ? 'filter-toggle-on' : ''}}"
                  catchtap="toggleUserMarkerType"
                  data-typeid="{{sub.id}}"
                >
                  <view class="filter-toggle-thumb"></view>
                </view>
              </view>
            </view>
          </view>
          <!-- 可展开的精选大类 -->
          <view class="filter-group" wx:for="{{quickCategories}}" wx:key="name" wx:for-item="group">
            <view class="filter-group-header" catchtap="toggleGroup" data-group="{{group.name}}">
              <text class="filter-group-icon">{{group.emoji}}</text>
              <text class="filter-group-name">{{group.cnName}}</text>
              <text class="filter-group-count">{{sectionSelectedCounts[group.name] || 0}}/{{poiGroupCounts[group.name]}}</text>
              <text class="filter-group-arrow {{expandedGroups[group.name] ? 'filter-group-arrow-expanded' : ''}}">▸</text>
            </view>
            <view class="filter-subs" wx:if="{{expandedGroups[group.name]}}">
              <view class="filter-sub" wx:for="{{group.subs}}" wx:for-item="sub" wx:for-index="catIdStr" wx:key="catIdStr">
                <text class="filter-sub-name">{{sub.emoji}} {{sub.cnName}}</text>
                <text class="filter-sub-count">{{poiCatCounts[catIdStr] || 0}}</text>
                <view
                  class="filter-toggle {{activePoiMap[catIdStr] ? 'filter-toggle-on' : ''}} {{activePoiCats.length >= 5 && !activePoiMap[catIdStr] ? 'filter-toggle-disabled' : ''}}"
                  catchtap="togglePoiSub"
                  data-catid="{{catIdStr}}"
                >
                  <view class="filter-toggle-thumb"></view>
                </view>
              </view>
            </view>
          </view>
          <!-- 直选小类 -->
          <view class="filter-quick-item" wx:for="{{quickSubs}}" wx:key="id" wx:for-item="qf">
            <text class="filter-sub-name">{{qf.emoji}} {{qf.cnName}}</text>
            <view
              class="filter-toggle {{activePoiMap[qf.id] ? 'filter-toggle-on' : ''}} {{activePoiCats.length >= 5 && !activePoiMap[qf.id] ? 'filter-toggle-disabled' : ''}}"
              catchtap="togglePoiSub"
              data-catid="{{qf.id}}"
            >
              <view class="filter-toggle-thumb"></view>
            </view>
          </view>
          <view class="filter-more-btn" catchtap="toggleFilterMode">
            <text class="filter-more-text">📂 更多类目</text>
            <text class="filter-more-arrow">▸</text>
          </view>
        </view>
        <!-- 完整模式 -->
        <view wx:else>
          <!-- 自定义标记大类 -->
          <view class="filter-group">
            <view class="filter-group-header" catchtap="toggleGroup" data-group="_custom">
              <text class="filter-group-icon">📌</text>
              <text class="filter-group-name">自定义标记</text>
              <text class="filter-group-count">{{sectionSelectedCounts['_custom'] || 0}}/4</text>
              <view class="filter-toggle {{showUserMarkers ? 'filter-toggle-on' : ''}}" catchtap="toggleShowUserMarkers">
                <view class="filter-toggle-thumb"></view>
              </view>
            </view>
            <view class="filter-subs" wx:if="{{expandedGroups['_custom']}}">
              <view class="filter-sub" wx:for="{{userMarkerFilterTypes}}" wx:for-item="sub" wx:key="id">
                <text class="filter-sub-name">{{sub.emoji}} {{sub.cnName}}</text>
                <text class="filter-sub-count">{{userMarkerTypeCounts[sub.id] || 0}}</text>
                <view
                  class="filter-toggle {{activeUserMarkerMap[sub.id] ? 'filter-toggle-on' : ''}}"
                  catchtap="toggleUserMarkerType"
                  data-typeid="{{sub.id}}"
                >
                  <view class="filter-toggle-thumb"></view>
                </view>
              </view>
            </view>
          </view>
          <view class="filter-group" wx:for="{{poiCategories}}" wx:key="name" wx:for-item="group">
            <view class="filter-group-header" catchtap="toggleGroup" data-group="{{group.name}}">
              <text class="filter-group-icon">{{group.emoji}}</text>
              <text class="filter-group-name">{{group.cnName}}</text>
              <text class="filter-group-count">{{sectionSelectedCounts[group.name] || 0}}/{{poiGroupCounts[group.name]}}</text>
              <text class="filter-group-arrow {{expandedGroups[group.name] ? 'filter-group-arrow-expanded' : ''}}">▸</text>
            </view>
            <view class="filter-subs" wx:if="{{expandedGroups[group.name]}}">
              <view class="filter-sub" wx:for="{{group.subs}}" wx:for-item="sub" wx:for-index="catIdStr" wx:key="catIdStr">
                <text class="filter-sub-name">{{sub.emoji}} {{sub.cnName}}</text>
                <text class="filter-sub-count">{{poiCatCounts[catIdStr] || 0}}</text>
                <view
                  class="filter-toggle {{activePoiMap[catIdStr] ? 'filter-toggle-on' : ''}} {{activePoiCats.length >= 5 && !activePoiMap[catIdStr] ? 'filter-toggle-disabled' : ''}}"
                  catchtap="togglePoiSub"
                  data-catid="{{catIdStr}}"
                >
                  <view class="filter-toggle-thumb"></view>
                </view>
              </view>
            </view>
          </view>
          <view class="filter-more-btn" catchtap="toggleFilterMode">
            <text class="filter-more-text">📂 收起</text>
            <text class="filter-more-arrow filter-more-arrow-expanded">▸</text>
          </view>
        </view>
      </view>
      <view class="filter-footer" catchtap="noop">
        <text class="filter-footer-text">最多同时开启 5 个小类</text>
      </view>
    </view>
  </view>

  <!-- 保存确认弹窗 -->
  <view class="save-confirm-mask" wx:if="{{showSaveConfirm}}" catchtap="onSaveCancel">
    <view class="save-confirm-dialog" catchtap="noop">
      <view class="save-confirm-title">保存到本地</view>
      <view class="save-confirm-content">确定将当前内容保存到本地？这会覆盖已有的本地存档。</view>
      <view class="save-confirm-actions">
        <view class="save-confirm-btn backup" catchtap="onSaveBackup">覆盖前备份</view>
        <view class="save-confirm-btn cancel" catchtap="onSaveCancel">取消</view>
        <view class="save-confirm-btn confirm" catchtap="onSaveConfirm">确定</view>
      </view>
    </view>
  </view>
</view>
