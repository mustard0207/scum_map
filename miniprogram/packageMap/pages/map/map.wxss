/* 地图页样式 — 生存终端主题 */
.map-page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #121008;
  position: relative;
}



/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(28, 26, 16, 0.95);
  border-bottom: 1rpx solid #3A3520;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #FFB000;
  font-weight: 300;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #D4C8A0;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.nav-placeholder {
  width: 60rpx;
}

/* 地图区域 */
.map-area {
  position: fixed;
  left: 0;
  right: 0;
}

/* 十字光标（固定在屏幕正中央） */
.crosshair {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  z-index: 50;
  pointer-events: none;
}

.crosshair-h {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: rgba(255, 176, 0, 0.8);
  transform: translateY(-50%);
}

.crosshair-v {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: rgba(255, 176, 0, 0.8);
  transform: translateX(-50%);
}

/* 缩放拖拉条 */
.zoom-slider {
  position: fixed;
  right: 32rpx;
  z-index: 50;
  width: 56rpx;
  height: 400rpx;
  opacity: 0.6;
  transition: opacity 0.3s;
  background: rgba(28, 26, 16, 0.85);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: blur(10px);
}
.zoom-slider.active {
  opacity: 1;
}

.zoom-slider-track {
  position: absolute;
  top: 50rpx;
  bottom: 50rpx;
  left: 50%;
  width: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  transform: translateX(-50%);
  border-radius: 2rpx;
}

.zoom-slider-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 176, 0, 0.7);
  border-radius: 2rpx;
}

.zoom-slider-thumb {
  position: absolute;
  left: 50%;
  width: 28rpx;
  height: 28rpx;
  background: #fff;
  border-radius: 50%;
  transform: translate(-50%, 50%);
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3);
  pointer-events: none;
}

.zoom-slider-label {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  pointer-events: none;
}

.zoom-slider-label:first-child {
  top: 6rpx;
}

.zoom-slider-label-bottom {
  top: auto;
  bottom: 6rpx;
}

/* 回到全局视角按钮 */
.reset-view-btn {
  position: fixed;
  right: 24rpx;
  z-index: 50;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(28, 26, 16, 0.85);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 50%;
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 6rpx rgba(0,0,0,0.3);
}

.reset-view-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.1);
}

.reset-icon-ring {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 176, 0, 0.7);
  border-radius: 50%;
  box-sizing: border-box;
  transition: all 0.2s;
}

.reset-icon-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background-color: rgba(255, 176, 0, 0.7);
  border-radius: 50%;
  transition: all 0.2s;
}

.reset-view-btn:active .reset-icon-ring {
  border-color: rgba(255, 176, 0, 1);
}

.reset-view-btn:active .reset-icon-dot {
  background-color: rgba(255, 176, 0, 1);
}

.crosshair-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  background: #FFB000;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* 坐标面板 */
.coord-panel {
  position: fixed;
  left: 20rpx;
  z-index: 50;
  background: rgba(28, 26, 16, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
  border: 1rpx solid #3A3520;
}

.coord-text {
  font-size: 22rpx;
  color: #FFB000;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
}

/* 信息窗口（点击标记后显示） */
.info-window-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-window {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  overflow: hidden;
}

.info-window-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  background: rgba(255, 176, 0, 0.08);
  border-bottom: 1rpx solid #3A3520;
}

.info-window-title-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.info-window-icon {
  font-size: 36rpx;
  color: #FFB000;
  flex-shrink: 0;
}

.info-window-title-wrap {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.info-window-title {
  font-size: 30rpx;
  color: #D4C8A0;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-window-subtitle {
  font-size: 20rpx;
  color: #7A6B4A;
  margin-top: 4rpx;
}

.info-window-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #7A6B4A;
  flex-shrink: 0;
  border-radius: 8rpx;
}

.info-window-close:active {
  background: rgba(255, 176, 0, 0.1);
}

.info-window-body {
  padding: 28rpx 30rpx;
}

.info-window-coord-row {
  display: flex;
  justify-content: space-around;
}

.info-window-coord-label {
  font-size: 20rpx;
  color: #7A6B4A;
  text-align: center;
  flex: 1;
}

.info-window-coord-value {
  font-size: 30rpx;
  color: #FFB000;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  font-weight: 600;
  text-align: center;
  flex: 1;
  margin-top: 8rpx;
}

/* 标记类型选择器 */
.info-window-type-selector {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #3A3520;
}

.type-btn {
  flex: 1;
  font-size: 22rpx;
  padding: 14rpx 0;
  border-radius: 8rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.06);
  color: #A09880;
  border: 1rpx solid #3A3520;
  font-weight: 600;
}

.type-btn-active {
  border-color: transparent;
}

.info-window-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #3A3520;
}

.info-window-tip {
  padding: 12rpx 30rpx;
  background: rgba(255, 176, 0, 0.05);
  border-top: 1rpx solid #3A3520;
}

.info-window-tip-text {
  font-size: 20rpx;
  color: #7A6B4A;
  line-height: 1.5;
}

.info-window-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-window-btn.delete {
  background: rgba(255, 68, 68, 0.1);
  color: #FF4444;
  border: 1rpx solid rgba(255, 68, 68, 0.3);
}

.info-window-btn.delete:active {
  background: rgba(255, 68, 68, 0.2);
}

.info-window-btn.copy {
  background: #2A2618;
  color: #D4C8A0;
  border: 1rpx solid #3A3520;
}

.info-window-btn.copy:active {
  background: #3A3520;
}

.info-window-btn.share {
  background: #FFB000;
  color: #121008;
  border: none;
}

.info-window-btn.share:active {
  background: #E69E00;
}

/* 分享按钮（<button> 去掉微信默认外观，与其他按钮对齐） */
button.info-window-btn {
  margin: 0;
  padding: 18rpx 0;
  line-height: 1.4;
  border: none;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 600;
}

button.info-window-btn::after {
  border: none;
}

/* 维护按钮 */
.info-window-btn.maintain {
  background: rgba(100, 180, 255, 0.1);
  color: #64B4FF;
}

/* 过期信息区块 */
.info-window-expiry {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #3A3520;
}

.expiry-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 0;
}

.expiry-label {
  font-size: 22rpx;
  color: #7A6B4A;
}

.expiry-value {
  font-size: 22rpx;
  color: #D4C8A0;
  font-family: 'Menlo', 'Courier New', monospace;
}

.expiry-warning {
  color: #FF4444;
  font-weight: 600;
}

.expiry-safe {
  color: #6BBF59;
}

.expiry-editable {
  text-decoration: underline;
  text-decoration-style: dotted;
  text-decoration-color: #7A6B4A;
  text-underline-offset: 4rpx;
}

/* 时效设置按钮 */
.expiry-setting-btn {
  background: rgba(255, 255, 255, 0.04) !important;
  color: #7A6B4A !important;
  font-size: 20rpx !important;
  flex: 0 0 auto !important;
  padding: 14rpx 16rpx !important;
}

/* 过期设置弹窗 */
.expiry-settings-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.expiry-settings-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  padding: 30rpx;
}

.expiry-settings-title {
  font-size: 30rpx;
  color: #D4C8A0;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12rpx;
}

.expiry-settings-hint {
  font-size: 22rpx;
  color: #7A6B4A;
  text-align: center;
  margin-bottom: 24rpx;
}

.expiry-settings-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #2A2618;
}

.expiry-settings-divider {
  height: 1rpx;
  background: #3A3520;
  margin: 16rpx 0;
}

.expiry-settings-label {
  flex: 1;
  font-size: 26rpx;
  color: #D4C8A0;
}

.expiry-settings-input {
  width: 120rpx;
  text-align: center;
  background: #2A2618;
  border: 1rpx solid #3A3520;
  border-radius: 8rpx;
  color: #FFB000;
  font-size: 28rpx;
  padding: 8rpx 0;
}

.expiry-settings-unit {
  font-size: 22rpx;
  color: #7A6B4A;
  margin-left: 12rpx;
}

.expiry-settings-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.expiry-settings-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.expiry-settings-btn.cancel {
  background: #2A2618;
  color: #7A6B4A;
  border: 1rpx solid #3A3520;
}

.expiry-settings-btn.confirm {
  background: #FFB000;
  color: #121008;
}

button.bar-btn {
  margin: 0;
  padding: 10rpx 0;
  background: transparent;
  border: none;
  line-height: normal;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: normal;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: auto;
  min-height: auto;
}

button.bar-btn::after {
  border: none;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-evenly;
  padding: 20rpx 0;
  background: rgba(28, 26, 16, 0.95);
  z-index: 100;
}

.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 10rpx 0;
  flex: 1;
}

.bar-btn:active {
  background: rgba(255, 176, 0, 0.08);
}

.bar-btn-disabled {
  opacity: 0.65;
}

.bar-icon {
  font-size: 48rpx;
  color: #7A6B4A;
  height: 56rpx;
  line-height: 56rpx;
}

.bar-label {
  font-size: 24rpx;
  color: #7A6B4A;
  font-weight: normal;
}

.bar-sublabel {
  font-size: 18rpx;
  color: #5A4D35;
  line-height: 1.2;
}

/* 备份抽屉 */
.data-drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.data-drawer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1C1A10;
  border-top: 1rpx solid #3A3520;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.data-drawer-tip {
  padding: 20rpx 40rpx;
  background: rgba(255, 176, 0, 0.05);
  border-bottom: 1rpx solid #2A2618;
}

.data-drawer-tip-text {
  font-size: 22rpx;
  color: #7A6B4A;
  line-height: 1.5;
}

.data-drawer-item {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
}

.data-drawer-item:active {
  background: rgba(255, 176, 0, 0.06);
}

.data-drawer-item + .data-drawer-item {
  border-top: 1rpx solid #3A3520;
}

.data-drawer-accent {
  width: 6rpx;
  height: 48rpx;
  background: #FFB000;
  border-radius: 3rpx;
  margin-right: 24rpx;
}

.data-drawer-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-drawer-title {
  font-size: 28rpx;
  color: #D4C8A0;
  font-weight: 600;
}

.data-drawer-desc {
  font-size: 22rpx;
  color: #7A6B4A;
}

.data-drawer-danger .data-drawer-accent {
  background: #C75050;
}

.data-drawer-danger .data-drawer-title {
  color: #C75050;
}

/* 坐标输入弹窗 */
.coord-input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coord-input-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  padding: 40rpx;
}

.coord-input-title {
  font-size: 32rpx;
  color: #D4C8A0;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.coord-input-hint {
  font-size: 22rpx;
  color: #7A6B4A;
  text-align: center;
  margin-bottom: 30rpx;
}

.hint-line {
  display: block;
  line-height: 1.6;
}

.hint-highlight {
  color: #FFB000;
  margin: 8rpx 0;
}

.hint-dim {
  color: #5A4D35;
  font-size: 20rpx;
}

.coord-input-field {
  width: 100%;
  height: 80rpx;
  background: #121008;
  border: 1rpx solid #3A3520;
  border-radius: 8rpx;
  padding: 0 20rpx;
  color: #FFB000;
  font-size: 28rpx;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  margin-bottom: 30rpx;
}

.coord-input-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.coord-input-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.coord-input-btn.cancel {
  background: #2A2618;
  color: #7A6B4A;
  border: 1rpx solid #3A3520;
}

.coord-input-btn.confirm {
  background: #FFB000;
  color: #121008;
}

/* 导入弹窗 */
.import-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.import-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  padding: 40rpx;
}

.import-title {
  font-size: 32rpx;
  color: #D4C8A0;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.import-hint {
  font-size: 22rpx;
  color: #7A6B4A;
  text-align: center;
  margin-bottom: 30rpx;
}

.import-field {
  width: 100%;
  height: 200rpx;
  background: #121008;
  border: 1rpx solid #3A3520;
  border-radius: 8rpx;
  padding: 20rpx;
  color: #FFB000;
  font-size: 24rpx;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  margin-bottom: 30rpx;
}

.import-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.import-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.import-btn.cancel {
  background: #2A2618;
  color: #7A6B4A;
  border: 1rpx solid #3A3520;
}

.import-btn.confirm {
  background: #FFB000;
  color: #121008;
}

/* 筛选面板（底部抽屉） */
.filter-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.filter-panel-mask-tap {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.filter-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 75vh;
  background: #1C1A10;
  border-top: 1rpx solid #3A3520;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1;
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #3A3520;
  flex-shrink: 0;
}

.filter-title {
  font-size: 30rpx;
  color: #D4C8A0;
  font-weight: 600;
}

.filter-reset {
  font-size: 24rpx;
  color: #7A6B4A;
  margin-right: 16rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid #3A3520;
  border-radius: 6rpx;
}

.filter-reset:active {
  color: #FFB000;
  border-color: #FFB000;
}

.filter-count {
  font-size: 24rpx;
  color: #7A6B4A;
  margin-right: 20rpx;
}

.filter-count-full {
  color: #FFB000;
}

.filter-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #7A6B4A;
}

.filter-close:active {
  color: #FFB000;
}

.filter-body {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-tip {
  padding: 16rpx 30rpx;
  background: rgba(255, 176, 0, 0.05);
  border-bottom: 1rpx solid #2A2618;
}

.filter-tip-text {
  font-size: 20rpx;
  color: #7A6B4A;
  line-height: 1.5;
}

/* 大类行 */
.filter-group {
  border-bottom: 1rpx solid #2A2618;
}

.filter-group-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.filter-group-header:active {
  background: rgba(255, 176, 0, 0.06);
}

.filter-group-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.filter-group-name {
  flex: 1;
  font-size: 28rpx;
  color: #D4C8A0;
  font-weight: 500;
}

.filter-group-count {
  font-size: 22rpx;
  color: #7A6B4A;
  margin-right: 12rpx;
}

.filter-group-arrow {
  font-size: 24rpx;
  color: #7A6B4A;
  transition: transform 0.2s;
}

.filter-group-arrow-expanded {
  transform: rotate(90deg);
}

/* 小类列表 */
.filter-subs {
  padding: 0 30rpx 16rpx;
}

.filter-sub {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.filter-sub + .filter-sub {
  border-top: 1rpx solid #1C1A10;
}

.filter-sub-name {
  flex: 1;
  font-size: 26rpx;
  color: #D4C8A0;
  padding-left: 56rpx;
}

.filter-sub-count {
  font-size: 22rpx;
  color: #7A6B4A;
  margin-right: 16rpx;
  min-width: 60rpx;
  text-align: right;
}

/* Toggle 开关 */
.filter-toggle {
  width: 76rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #2A2618;
  position: relative;
  flex-shrink: 0;
  transition: background 0.2s;
}

.filter-toggle-on {
  background: rgba(255, 176, 0, 0.8);
}

.filter-toggle-disabled {
  opacity: 0.35;
}

.filter-toggle-thumb {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #7A6B4A;
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  transition: transform 0.2s, background 0.2s;
}

.filter-toggle-on .filter-toggle-thumb {
  transform: translateX(36rpx);
  background: #121008;
}

/* 底部提示 */
/* 精简模式：常用小类 */
.filter-quick-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 30rpx;
}

.filter-quick-item + .filter-quick-item {
  border-top: 1rpx solid #1C1A10;
}

/* 更多类目按钮 */
.filter-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #3A3520;
}

.filter-more-btn:active {
  background: rgba(255, 176, 0, 0.06);
}

.filter-more-text {
  font-size: 26rpx;
  color: #FFB000;
}

.filter-more-arrow {
  font-size: 24rpx;
  color: #FFB000;
  margin-left: 8rpx;
}

.filter-more-arrow-expanded {
  transform: rotate(90deg);
}

.filter-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #3A3520;
  text-align: center;
  flex-shrink: 0;
}

.filter-footer-text {
  font-size: 22rpx;
  color: #7A6B4A;
}

/* 分享内容提示条 */
.save-banner {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  background: #2A2518;
  border-top: 1rpx solid #3A3520;
}

.save-banner-text {
  font-size: 24rpx;
  color: #C0B896;
}

.save-banner-btn {
  font-size: 24rpx;
  color: #6BBF59;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border: 1rpx solid #6BBF59;
  border-radius: 8rpx;
}

/* 保存确认弹窗 */
.save-confirm-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 300;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-confirm-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  overflow: hidden;
}

.save-confirm-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #E8E0C8;
  padding: 30rpx 30rpx 16rpx;
  text-align: center;
}

.save-confirm-content {
  font-size: 26rpx;
  color: #A09880;
  padding: 0 30rpx 30rpx;
  text-align: center;
  line-height: 1.5;
}

.save-confirm-actions {
  display: flex;
  border-top: 1rpx solid #3A3520;
}

.save-confirm-btn {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  padding: 24rpx 0;
  text-align: center;
}

.save-confirm-btn + .save-confirm-btn {
  border-left: 1rpx solid #3A3520;
}

.save-confirm-btn.backup {
  color: #E8873C;
}

.save-confirm-btn.cancel {
  color: #A09880;
}

.save-confirm-btn.confirm {
  color: #6BBF59;
}

/* 载具管理面板 */
.vehicle-panel {
  margin-top: 24rpx;
  background: rgba(40, 38, 28, 0.4);
  border: 2rpx solid rgba(255, 176, 0, 0.2);
  border-radius: 12rpx;
  overflow: hidden;
}

.vehicle-selector-wrap {
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(255, 176, 0, 0.1);
}

.vehicle-selector {
  white-space: nowrap;
  width: 100%;
}

.vehicle-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  opacity: 0.5;
  transition: all 0.2s;
}

.vehicle-item-active {
  opacity: 1;
  background: rgba(255, 176, 0, 0.1);
  border-radius: 8rpx;
}

.vehicle-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.vehicle-name {
  font-size: 26rpx;
  color: #DDD;
}

.vehicle-parts-panel {
  padding: 24rpx;
}

.vehicle-parts-collapsed {
  padding: 32rpx 24rpx;
  display: flex;
  justify-content: center;
}

.btn-mark-incomplete {
  background: rgba(255, 176, 0, 0.1);
  border: 2rpx dashed rgba(255, 176, 0, 0.4);
  border-radius: 8rpx;
  padding: 16rpx 48rpx;
  color: #E8873C;
  font-size: 26rpx;
  transition: all 0.2s;
}

.btn-mark-incomplete:active {
  background: rgba(255, 176, 0, 0.2);
}

.btn-reset-complete {
  margin-top: 16rpx;
  padding: 16rpx;
  text-align: center;
  color: #A09880;
  font-size: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.05);
}

.btn-reset-complete:active {
  background: rgba(255, 255, 255, 0.05);
}

.parts-chassis {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.parts-col {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
}

.parts-col.parts-center {
  align-items: center;
}

.parts-col.parts-left {
  align-items: flex-end;
}

.parts-col.parts-right {
  align-items: flex-start;
}

.part-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(28, 26, 16, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.part-active {
  border-color: rgba(107, 191, 89, 0.5);
  background: rgba(107, 191, 89, 0.1);
}

.part-missing {
  opacity: 0.4;
  filter: grayscale(100%);
}

.part-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #666;
}

.part-active .part-indicator {
  background: #6BBF59;
  box-shadow: 0 0 8rpx rgba(107, 191, 89, 0.6);
}

.part-name {
  font-size: 24rpx;
  color: #CCC;
}

.part-active .part-name {
  color: #FFF;
  font-weight: bold;
}

.vehicle-wheels-stepper {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stepper-label {
  font-size: 26rpx;
  color: #CCC;
}

.stepper-ctrl {
  display: flex;
  align-items: center;
  background: rgba(28, 26, 16, 0.6);
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.stepper-btn {
  width: 60rpx;
  height: 52rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #FFF;
  font-weight: bold;
}

.stepper-btn:active {
  background: rgba(255, 176, 0, 0.2);
}

.stepper-val {
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #FFF;
  font-weight: bold;
  border-left: 2rpx solid rgba(255, 255, 255, 0.1);
  border-right: 2rpx solid rgba(255, 255, 255, 0.1);
}

.vehicle-parts-empty {
  padding: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #888;
}
