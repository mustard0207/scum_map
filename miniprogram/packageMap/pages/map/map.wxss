/* 地图页样式 — 生存终端主题 */
.map-page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #121008;
  position: relative;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(28, 26, 16, 0.95);
  border-bottom: 1rpx solid #3A3520;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #FFB000;
  font-weight: 300;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #D4C8A0;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.nav-placeholder {
  width: 60rpx;
}

/* 地图区域 */
.map-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 140rpx; /* 避开底部操作栏 */
  top: 0;
}

/* 十字光标（固定在屏幕正中央） */
.crosshair {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  z-index: 50;
  pointer-events: none;
}

.crosshair-h {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: rgba(255, 176, 0, 0.8);
  transform: translateY(-50%);
}

.crosshair-v {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: rgba(255, 176, 0, 0.8);
  transform: translateX(-50%);
}

.crosshair-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  background: #FFB000;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* 坐标面板 */
.coord-panel {
  position: fixed;
  right: 20rpx;
  z-index: 50;
  background: rgba(28, 26, 16, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
  border: 1rpx solid #3A3520;
}

.coord-text {
  font-size: 22rpx;
  color: #FFB000;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
}

/* 信息窗口（点击标记后显示） */
.info-window-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-window {
  width: 70%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  overflow: hidden;
}

.info-window-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: rgba(255, 176, 0, 0.1);
  border-bottom: 1rpx solid #3A3520;
}

.info-window-title {
  font-size: 30rpx;
  color: #D4C8A0;
  font-weight: 600;
}

.info-window-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #7A6B4A;
}

.info-window-body {
  padding: 30rpx;
}

.info-window-coord {
  display: block;
  font-size: 26rpx;
  color: #FFB000;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  margin-bottom: 10rpx;
}

.info-window-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #3A3520;
}

.info-window-btn {
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-weight: 600;
  text-align: center;
}

.info-window-btn.delete {
  background: #2A2618;
  color: #FF4444;
  border: 1rpx solid #FF4444;
}

.info-window-btn.copy {
  background: #2A2618;
  color: #D4C8A0;
  border: 1rpx solid #3A3520;
}

.info-window-btn.share {
  background: #FFB000;
  color: #121008;
}

/* 信息窗口分享按钮（open-type="share" 需要 <button>，去掉微信默认外观） */
button.info-window-btn {
  margin: 0;
  padding: 16rpx 24rpx;
  line-height: 1.4;
  border: none;
  box-sizing: border-box;
}

button.info-window-btn::after {
  border: none;
}

button.bar-btn {
  margin: 0;
  padding: 10rpx 0;
  background: transparent;
  border: none;
  line-height: normal;
  box-sizing: border-box;
  font-size: inherit;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: auto;
  min-height: auto;
}

button.bar-btn::after {
  border: none;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  background: rgba(28, 26, 16, 0.95);
  border-top: 1rpx solid #3A3520;
}

.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 30rpx;
}

.bar-btn:active {
  background: rgba(255, 176, 0, 0.08);
}

.bar-icon {
  font-size: 40rpx;
  color: #7A6B4A;
}

.bar-label {
  font-size: 22rpx;
  color: #7A6B4A;
}

/* 坐标输入弹窗 */
.coord-input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coord-input-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  padding: 40rpx;
}

.coord-input-title {
  font-size: 32rpx;
  color: #D4C8A0;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.coord-input-hint {
  font-size: 22rpx;
  color: #7A6B4A;
  text-align: center;
  margin-bottom: 30rpx;
}

.coord-input-field {
  width: 100%;
  height: 80rpx;
  background: #121008;
  border: 1rpx solid #3A3520;
  border-radius: 8rpx;
  padding: 0 20rpx;
  color: #FFB000;
  font-size: 28rpx;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  margin-bottom: 30rpx;
}

.coord-input-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.coord-input-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.coord-input-btn.cancel {
  background: #2A2618;
  color: #7A6B4A;
  border: 1rpx solid #3A3520;
}

.coord-input-btn.confirm {
  background: #FFB000;
  color: #121008;
}

/* 导入弹窗 */
.import-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.import-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  padding: 40rpx;
}

.import-title {
  font-size: 32rpx;
  color: #D4C8A0;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.import-hint {
  font-size: 22rpx;
  color: #7A6B4A;
  text-align: center;
  margin-bottom: 30rpx;
}

.import-field {
  width: 100%;
  height: 200rpx;
  background: #121008;
  border: 1rpx solid #3A3520;
  border-radius: 8rpx;
  padding: 20rpx;
  color: #FFB000;
  font-size: 24rpx;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  margin-bottom: 30rpx;
}

.import-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.import-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.import-btn.cancel {
  background: #2A2618;
  color: #7A6B4A;
  border: 1rpx solid #3A3520;
}

.import-btn.confirm {
  background: #FFB000;
  color: #121008;
}
