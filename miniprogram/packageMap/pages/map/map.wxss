/* 地图页样式 — 生存终端主题 */
.map-page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #121008;
  position: relative;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(28, 26, 16, 0.95);
  border-bottom: 1rpx solid #3A3520;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #FFB000;
  font-weight: 300;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #D4C8A0;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.nav-placeholder {
  width: 60rpx;
}

/* 地图区域 */
.map-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 140rpx; /* 避开底部操作栏 */
  top: 0;
}

/* 十字光标（固定在屏幕正中央） */
.crosshair {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  z-index: 50;
  pointer-events: none;
}

.crosshair-h {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: rgba(255, 176, 0, 0.8);
  transform: translateY(-50%);
}

.crosshair-v {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: rgba(255, 176, 0, 0.8);
  transform: translateX(-50%);
}

/* 回到全局视角按钮 */
.reset-view-btn {
  position: fixed;
  left: 20rpx;
  z-index: 50;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(28, 26, 16, 0.7);
  border: 1rpx solid rgba(58, 53, 32, 0.6);
  border-radius: 50%;
}

.reset-view-btn:active {
  background: rgba(255, 176, 0, 0.15);
}

.reset-view-icon {
  font-size: 40rpx;
  color: rgba(255, 176, 0, 0.7);
}

.crosshair-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  background: #FFB000;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* 坐标面板 */
.coord-panel {
  position: fixed;
  right: 20rpx;
  z-index: 50;
  background: rgba(28, 26, 16, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
  border: 1rpx solid #3A3520;
}

.coord-text {
  font-size: 22rpx;
  color: #FFB000;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
}

/* 信息窗口（点击标记后显示） */
.info-window-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-window {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  overflow: hidden;
}

.info-window-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  background: rgba(255, 176, 0, 0.08);
  border-bottom: 1rpx solid #3A3520;
}

.info-window-title-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.info-window-icon {
  font-size: 36rpx;
  color: #FFB000;
  flex-shrink: 0;
}

.info-window-title-wrap {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.info-window-title {
  font-size: 30rpx;
  color: #D4C8A0;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-window-subtitle {
  font-size: 20rpx;
  color: #7A6B4A;
  margin-top: 4rpx;
}

.info-window-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #7A6B4A;
  flex-shrink: 0;
  border-radius: 8rpx;
}

.info-window-close:active {
  background: rgba(255, 176, 0, 0.1);
}

.info-window-body {
  padding: 28rpx 30rpx;
}

.info-window-coord-row {
  display: flex;
  justify-content: space-around;
}

.info-window-coord-label {
  font-size: 20rpx;
  color: #7A6B4A;
  text-align: center;
  flex: 1;
}

.info-window-coord-value {
  font-size: 30rpx;
  color: #FFB000;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  font-weight: 600;
  text-align: center;
  flex: 1;
  margin-top: 8rpx;
}

.info-window-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #3A3520;
}

.info-window-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-window-btn.delete {
  background: rgba(255, 68, 68, 0.1);
  color: #FF4444;
  border: 1rpx solid rgba(255, 68, 68, 0.3);
}

.info-window-btn.delete:active {
  background: rgba(255, 68, 68, 0.2);
}

.info-window-btn.copy {
  background: #2A2618;
  color: #D4C8A0;
  border: 1rpx solid #3A3520;
}

.info-window-btn.copy:active {
  background: #3A3520;
}

.info-window-btn.share {
  background: #FFB000;
  color: #121008;
  border: none;
}

.info-window-btn.share:active {
  background: #E69E00;
}

/* 分享按钮（<button> 去掉微信默认外观，与其他按钮对齐） */
button.info-window-btn {
  margin: 0;
  padding: 18rpx 0;
  line-height: 1.4;
  border: none;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 600;
}

button.info-window-btn::after {
  border: none;
}

button.bar-btn {
  margin: 0;
  padding: 10rpx 0;
  background: transparent;
  border: none;
  line-height: normal;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: normal;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: auto;
  min-height: auto;
}

button.bar-btn::after {
  border: none;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-evenly;
  padding: 20rpx 0;
  background: rgba(28, 26, 16, 0.95);
  border-top: 1rpx solid #3A3520;
  z-index: 100;
}

.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 10rpx 0;
  flex: 1;
}

.bar-btn:active {
  background: rgba(255, 176, 0, 0.08);
}

.bar-btn-disabled {
  opacity: 0.65;
}

.bar-icon {
  font-size: 48rpx;
  color: #7A6B4A;
  height: 56rpx;
  line-height: 56rpx;
}

.bar-label {
  font-size: 24rpx;
  color: #7A6B4A;
  font-weight: normal;
}

/* 备份抽屉 */
.data-drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.data-drawer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1C1A10;
  border-top: 1rpx solid #3A3520;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.data-drawer-item {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
}

.data-drawer-item:active {
  background: rgba(255, 176, 0, 0.06);
}

.data-drawer-item + .data-drawer-item {
  border-top: 1rpx solid #3A3520;
}

.data-drawer-accent {
  width: 6rpx;
  height: 48rpx;
  background: #FFB000;
  border-radius: 3rpx;
  margin-right: 24rpx;
}

.data-drawer-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-drawer-title {
  font-size: 28rpx;
  color: #D4C8A0;
  font-weight: 600;
}

.data-drawer-desc {
  font-size: 22rpx;
  color: #7A6B4A;
}

/* 坐标输入弹窗 */
.coord-input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coord-input-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  padding: 40rpx;
}

.coord-input-title {
  font-size: 32rpx;
  color: #D4C8A0;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.coord-input-hint {
  font-size: 22rpx;
  color: #7A6B4A;
  text-align: center;
  margin-bottom: 30rpx;
}

.coord-input-field {
  width: 100%;
  height: 80rpx;
  background: #121008;
  border: 1rpx solid #3A3520;
  border-radius: 8rpx;
  padding: 0 20rpx;
  color: #FFB000;
  font-size: 28rpx;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  margin-bottom: 30rpx;
}

.coord-input-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.coord-input-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.coord-input-btn.cancel {
  background: #2A2618;
  color: #7A6B4A;
  border: 1rpx solid #3A3520;
}

.coord-input-btn.confirm {
  background: #FFB000;
  color: #121008;
}

/* 导入弹窗 */
.import-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.import-dialog {
  width: 80%;
  background: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 16rpx;
  padding: 40rpx;
}

.import-title {
  font-size: 32rpx;
  color: #D4C8A0;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.import-hint {
  font-size: 22rpx;
  color: #7A6B4A;
  text-align: center;
  margin-bottom: 30rpx;
}

.import-field {
  width: 100%;
  height: 200rpx;
  background: #121008;
  border: 1rpx solid #3A3520;
  border-radius: 8rpx;
  padding: 20rpx;
  color: #FFB000;
  font-size: 24rpx;
  font-family: 'Menlo', 'Courier New', 'Consolas', monospace;
  margin-bottom: 30rpx;
}

.import-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.import-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.import-btn.cancel {
  background: #2A2618;
  color: #7A6B4A;
  border: 1rpx solid #3A3520;
}

.import-btn.confirm {
  background: #FFB000;
  color: #121008;
}
