/* ============================================
   SCUM游戏工具箱 — 「生存终端」主题
   琥珀 CRT 终端风格
   ============================================ */

/* 全局样式 */
page {
  background-color: #121008;
  color: #D4C8A0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: #1C1A10;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #3A3520;
}

/* 主色调 — 琥珀 */
.text-primary {
  color: #FFB000;
}

/* 强调色 — 暖红 */
.text-accent {
  color: #E85D3A;
}

/* 次要文字 */
.text-secondary {
  color: #7A6B4A;
}

/* 按钮 — 琥珀 */
.btn-primary {
  background: #FFB000;
  color: #121008;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary:active {
  background: #E69E00;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 首次引导遮罩 (全局复用) */
.guide-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(18, 16, 8, 0.82);
  backdrop-filter: blur(2px);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx 30rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.guide-content {
  width: 100%;
  max-width: 690rpx;
  margin: auto 0;
}

.guide-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.guide-main-title {
  display: block;
  font-size: 44rpx;
  color: #FFB000;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.guide-main-sub {
  display: block;
  font-size: 26rpx;
  color: #7A6B4A;
}

.guide-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  background: rgba(28, 26, 16, 0.8);
  border: 1rpx solid #3A3520;
  border-radius: 12rpx;
}

.guide-icon {
  font-size: 46rpx;
  color: #FFB000;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 50rpx;
  text-align: center;
}

.guide-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.guide-title {
  font-size: 30rpx;
  color: #D4C8A0;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.guide-desc {
  font-size: 26rpx;
  color: #7A6B4A;
  line-height: 1.5;
}

.guide-btn {
  margin-top: 24rpx;
  padding: 20rpx 80rpx;
  background: #FFB000;
  border-radius: 12rpx;
  text-align: center;
}

.guide-btn:active {
  background: #E69E00;
}

.guide-btn-text {
  font-size: 30rpx;
  color: #121008;
  font-weight: 600;
}

/* ===============================
   全局使用说明按钮 (Help Button)
   =============================== */
.global-help-btn {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0;
  margin-bottom: 10rpx;
}

.global-help-btn-floating {
  position: absolute;
  right: 30rpx;
  z-index: 90;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: rgba(28, 26, 16, 0.7);
  border: 1rpx solid #3A3520;
  border-radius: 30rpx;
  padding: 12rpx 20rpx;
  backdrop-filter: blur(4px);
}

.global-help-btn:active, .global-help-btn-floating:active {
  opacity: 0.7;
}

.help-icon-circle {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #7A6B4A;
  color: #7A6B4A;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-family: Arial, sans-serif;
}

.help-text-label {
  font-size: 24rpx;
  color: #7A6B4A;
}
