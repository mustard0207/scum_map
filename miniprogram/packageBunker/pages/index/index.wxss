/* 和主页类似的暗黑风格继承 */
.page {
  min-height: 100vh;
  background-color: #121008;
  color: #fff;
  box-sizing: border-box;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #1C1A10;
  border-bottom: 1px solid #333;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 15px;
}

.back-btn {
  font-size: 28px;
  color: #FFB000;
  padding: 0 15px;
  margin-left: -15px;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 16px;
  font-weight: bold;
  color: #fff;
}

.main {
  padding: 20px;
}

.list-container {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.feature-card {
  background-color: #1C1A10;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  align-items: center;
}

.feature-card:active:not(.disabled) {
  opacity: 0.8;
  background-color: #2a2718;
}

.feature-icon-area {
  width: 64px;
  height: 64px;
  background-color: #121008;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 15px;
}

.feature-glyph {
  font-size: 36px;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 18px;
  font-weight: bold;
  color: #FFB000;
  margin-bottom: 6px;
}

.feature-desc {
  font-size: 12px;
  color: #aaa;
}

.feature-arrow {
  font-size: 24px;
  color: #FFB000;
  margin-left: 10px;
}

.disabled {
  opacity: 0.6;
}
