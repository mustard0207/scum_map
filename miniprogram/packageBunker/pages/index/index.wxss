/* 和主页类似的暗黑风格继承 */
.page {
  min-height: 100vh;
  background-color: #121008;
  color: #D4C8A0;
  box-sizing: border-box;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #1C1A10;
  border-bottom: 1rpx solid #3A3520;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 30rpx;
}

.back-btn {
  font-size: 56rpx;
  color: #FFB000;
  padding: 0 30rpx;
  margin-left: -30rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 600;
  color: #D4C8A0;
  letter-spacing: 2rpx;
}

.main {
  padding: 40rpx 30rpx;
}

.list-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-card {
  background-color: #1C1A10;
  border: 1rpx solid #3A3520;
  border-radius: 12rpx;
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
  transition: all 0.2s;
}

.feature-card:active:not(.disabled) {
  border-color: #FFB000;
  background: #24210F;
}

.feature-icon-area {
  width: 96rpx;
  height: 96rpx;
  background-color: rgba(255, 176, 0, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-glyph {
  font-size: 48rpx;
  color: #FFB000;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #D4C8A0;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #7A6B4A;
}

.feature-arrow {
  font-size: 48rpx;
  color: #FFB000;
  font-weight: 300;
  margin-left: 10rpx;
}

.disabled {
  opacity: 0.6;
}
