.page {
  height: 100vh;
  background-color: #121008;
  color: #fff;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.nav-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #1C1A10;
  border-bottom: 1px solid #333;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 15px;
}

.back-btn {
  font-size: 28px;
  color: #FFB000;
  padding: 0 15px;
  margin-left: -15px;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  font-weight: bold;
  color: #fff;
  letter-spacing: 1px;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 顶部配置区 */
.config-section {
  padding: 20px 15px 10px;
  transition: opacity 0.3s;
}

.config-section.locked {
  opacity: 0.4;
  pointer-events: none;
}

.config-group {
  margin-bottom: 20px;
}

.config-label {
  font-size: 14px;
  color: #888;
  margin-bottom: 10px;
  text-align: center;
}

/* 安培数选择器 */
.amp-selector {
  display: flex;
  justify-content: space-between;
  gap: 5px;
}

.amp-btn {
  flex: 1;
  background: #1C1A10;
  border: 1px solid #333;
  border-radius: 4px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: bold;
  color: #aaa;
  transition: all 0.2s;
}

.amp-btn.active {
  background: rgba(255, 176, 0, 0.1);
  border-color: #FFB000;
  color: #FFB000;
  box-shadow: 0 0 8px rgba(255, 176, 0, 0.3);
}

/* 耐久度步进器 */
.durability-stepper {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 15px;
}

.step-group {
  display: flex;
  gap: 8px;
}

.step-btn {
  width: 50px;
  height: 44px;
  background: #2a2718;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: bold;
  color: #FFB000;
}

.step-btn:active {
  background: #FFB000;
  color: #000;
}

.durability-display {
  width: 90px;
  text-align: center;
}

.durability-val {
  font-size: 32px;
  font-weight: bold;
  color: #fff;
  font-family: 'Courier New', Courier, monospace;
}

.durability-unit {
  font-size: 16px;
  color: #FFB000;
  margin-left: 2px;
}

.estimate-time {
  text-align: center;
  font-size: 13px;
  color: #666;
  margin-top: 10px;
}

.estimate-time .highlight {
  color: #aaa;
  font-family: 'Courier New', Courier, monospace;
}

/* 中部倒计时区 */
.timer-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.timer-circle {
  width: 280px;
  height: 280px;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle, rgba(28,26,16,1) 0%, rgba(18,16,8,1) 100%);
  border: 4px solid #333;
  box-shadow: inset 0 0 30px rgba(0,0,0,0.8);
  transition: all 0.5s;
}

.time-display {
  font-size: 64px;
  font-weight: bold;
  font-family: 'Courier New', Courier, monospace;
  color: #555;
  letter-spacing: 2px;
  transition: color 0.3s;
}

.time-label {
  font-size: 16px;
  margin-top: 15px;
  color: #555;
  font-weight: bold;
  letter-spacing: 1px;
}

/* 警报状态颜色 */
.timer-circle.safe {
  border-color: #00ff41;
  box-shadow: 0 0 20px rgba(0, 255, 65, 0.2), inset 0 0 30px rgba(0,0,0,0.8);
}
.timer-circle.safe .time-display { color: #00ff41; }
.timer-circle.safe .time-label { color: #00ff41; }

.timer-circle.warning {
  border-color: #ff8800;
  box-shadow: 0 0 30px rgba(255, 136, 0, 0.4), inset 0 0 30px rgba(0,0,0,0.8);
}
.timer-circle.warning .time-display { color: #ff8800; }
.timer-circle.warning .time-label { color: #ff8800; }

.timer-circle.danger {
  border-color: #ff4444;
  box-shadow: 0 0 40px rgba(255, 68, 68, 0.6), inset 0 0 30px rgba(0,0,0,0.8);
  animation: pulse-danger 1s infinite alternate;
}
.timer-circle.danger .time-display { color: #ff4444; }
.timer-circle.danger .time-label { color: #ff4444; }

.timer-circle.dead {
  border-color: #333;
  background: #111;
  opacity: 0.5;
}
.timer-circle.dead .time-display { color: #ff4444; }
.timer-circle.dead .time-label { color: #ff4444; }

@keyframes pulse-danger {
  0% { box-shadow: 0 0 20px rgba(255, 68, 68, 0.3), inset 0 0 30px rgba(0,0,0,0.8); }
  100% { box-shadow: 0 0 60px rgba(255, 68, 68, 0.8), inset 0 0 30px rgba(0,0,0,0.8); }
}

/* 底部操作区 */
.controls-section {
  padding: 0 15px 40px;
}

.control-row {
  display: flex;
  gap: 15px;
}

.btn-reset {
  flex: 0.3;
  height: 64px;
  background: #1C1A10;
  border: 1px solid #333;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #888;
  font-size: 14px;
  font-weight: bold;
}

.btn-reset .icon {
  font-size: 20px;
  margin-bottom: 2px;
}

.btn-reset:active {
  background: #222;
  color: #fff;
}

.btn-main {
  flex: 0.7;
  height: 64px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: bold;
  letter-spacing: 1px;
  transition: all 0.2s;
}

.btn-start {
  background: #FFB000;
  color: #000;
  box-shadow: 0 4px 15px rgba(255, 176, 0, 0.3);
}

.btn-start:active {
  background: #e59e00;
  transform: translateY(2px);
}

.btn-pause {
  background: #ff4444;
  color: #fff;
  box-shadow: 0 4px 15px rgba(255, 68, 68, 0.3);
}

.btn-pause:active {
  background: #cc3333;
  transform: translateY(2px);
}
