.page {
  height: 100vh;
  background-color: #121008;
  color: #fff;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.nav-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #1C1A10;
  border-bottom: 1px solid #333;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 15px;
}

.back-btn {
  font-size: 28px;
  color: #FFB000;
  padding: 0 15px;
  margin-left: -15px;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  font-weight: bold;
  color: #fff;
  letter-spacing: 1px;
}

.reset-btn {
  position: absolute;
  right: 15px;
  font-size: 14px;
  color: #888;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.top-section {
  flex: 1;
  padding: 15px 15px 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.target-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20px;
  gap: 10px;
}

.target-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.target-label {
  font-size: 14px;
  color: #aaa;
  margin-bottom: 5px;
}

.target-input {
  width: 75px !important;
  height: 42px !important;
  font-size: 18px !important;
}

.target-arrow {
  color: #FFB000;
  font-size: 20px;
  margin-top: 20px;
}

.red-text { color: #ff4444 !important; }
.blue-text { color: #44ffff !important; }

.input-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
}

.mock-input {
  background: #000;
  border: 1px solid #444;
  height: 36px;
  width: 45px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Courier New', Courier, monospace;
  font-size: 16px;
  font-weight: bold;
}

.arrow {
  color: #FFB000;
  font-size: 16px;
}

.focused {
  border-color: #FFB000;
  box-shadow: 0 0 8px rgba(255, 176, 0, 0.4);
}

.red-input { color: #ff4444; flex: 1; margin: 0 5px; width: 40px; }
.blue-input { color: #44ffff; flex: 1; margin: 0 5px; width: 40px; }

.switches-grid {
  display: flex;
  justify-content: space-between;
  gap: 10px;
}

.grid-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.switch-row {
  background: #1C1A10;
  border: 1px solid #333;
  border-radius: 8px;
  padding: 8px 5px;
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.switch-index {
  color: #FFB000;
  font-family: 'Courier New', Courier, monospace;
  width: 22px;
  font-size: 16px;
  font-weight: bold;
  text-align: right;
  margin-right: 5px;
}

/* 结果高亮样式 */
.is-active {
  border-color: #00ff41;
  box-shadow: 0 0 10px rgba(0, 255, 65, 0.3);
  background: rgba(0, 255, 65, 0.05);
}

.is-dimmed {
  opacity: 0.3;
}

.bottom-section {
  position: relative;
}

/* 自定义键盘 */
.custom-keyboard {
  background: #121008;
  padding: 15px 10px 20px;
  border-top: 1px solid #333;
  box-shadow: 0 -5px 20px rgba(0,0,0,0.5);
}

.kb-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  gap: 8px;
}

.kb-key {
  flex: 1;
  height: 48px;
  background: #2a2718;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: bold;
  color: #fff;
}

.kb-key:active {
  background: #FFB000;
  color: #000;
}

.op-key { background: #3d3420; color: #FFB000; font-size: 26px; }
.fn-key { background: #333; font-size: 16px; font-weight: normal; }
.calc-btn {
  background: #FFB000;
  color: #000;
  flex: 1;
  height: 54px;
}

/* 结果面板 */
.result-panel {
  background: #1C1A10;
  padding: 30px 20px 40px;
  border-top: 2px solid #00ff41;
  box-shadow: 0 -10px 30px rgba(0, 255, 65, 0.1);
  text-align: center;
}

.result-title {
  font-size: 18px;
  font-weight: bold;
  color: #00ff41;
  margin-bottom: 15px;
}

.result-numbers {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin-bottom: 10px;
}

.result-badge {
  background: rgba(0, 255, 65, 0.2);
  color: #00ff41;
  border: 1px solid #00ff41;
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 16px;
  font-weight: bold;
}

.result-none {
  color: #888;
  font-size: 14px;
  margin: 15px 0;
}

.result-actions {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 25px;
}

.btn-secondary, .btn-primary {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  font-size: 16px;
  font-weight: bold;
  padding: 0 !important;
  box-sizing: border-box;
}

.btn-secondary {
  background: #333;
  color: #fff;
}

.btn-primary {
  background: #FFB000;
  color: #000;
}


