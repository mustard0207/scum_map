.page {
  height: 100vh;
  background: #121008;
  color: #D4C8A0;
  overflow: hidden;
}

.fixed-area {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 50;
  background: #121008;
  padding: 0 16px 12px;
}

.task-scroll {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px 16px 30px;
  box-sizing: border-box;
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #1C1A10;
  border-bottom: 1px solid #3A3520;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 15px;
}

.back-btn {
  font-size: 28px;
  color: #FFB000;
  padding: 0 15px;
  margin-left: -15px;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  font-weight: bold;
  color: #D4C8A0;
  letter-spacing: 1px;
}

/* 时钟区 */
.clock-section {
  position: relative;
  background: #1C1A10;
  border: 1px solid #3A3520;
  border-radius: 10px;
  padding: 14px 16px 6px;
  margin-top: 16px;
  margin-bottom: 10px;
  text-align: center;
}

.clock-label {
  position: absolute;
  top: -8px;
  left: 12px;
  padding: 1px 6px;
  font-size: 10px;
  font-weight: 600;
  border-radius: 3px;
  background: #2D2816;
  color: #FFB000;
  border: 1px solid #FFB000;
}

.clock-display {
  position: relative;
  text-align: center;
  margin-bottom: 0;
}

.clock-time {
  font-family: 'Menlo', 'Courier New', monospace;
  font-size: 42px;
  font-weight: bold;
  color: #FFB000;
  letter-spacing: 2px;
  line-height: 1.2;
}

.clock-uncalibrated {
  color: #7A6B4A;
}

.calibrate-btn-inline {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255, 176, 0, 0.15);
  border: 1px solid #FFB000;
  border-radius: 6px;
  padding: 6px 14px;
}

.calibrate-btn-inline:active {
  background: rgba(255, 176, 0, 0.3);
}

.recalibrate-inline {
  background: transparent;
  border-color: #3A3520;
}

.recalibrate-inline .calibrate-btn-inline-text {
  color: #7A6B4A;
}

.recalibrate-inline:active {
  border-color: #FFB000;
}

.recalibrate-inline:active .calibrate-btn-inline-text {
  color: #FFB000;
}

.calibrate-btn-inline-text {
  font-size: 13px;
  font-weight: 600;
  color: #FFB000;
}

.clock-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  margin-bottom: 18px;
  line-height: 1.2;
}

.clock-status-icon {
  font-size: 14px;
}

.status-day {
  color: #FFB000;
}

.status-night {
  color: #7A8599;
}

.clock-status-text {
  font-size: 13px;
  color: #D4C8A0;
}

.clock-status-uncal {
  color: #7A6B4A;
}

/* 倍率设置 */
.multiplier-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin-bottom: 16px;
}

.multiplier-label {
  font-size: 13px;
  color: #7A6B4A;
}

.multiplier-display {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #2D2816;
  border: 1px solid #3A3520;
  border-radius: 6px;
  padding: 4px 12px;
}

.multiplier-display:active {
  border-color: #FFB000;
}

.multiplier-value {
  font-size: 14px;
  color: #FFB000;
  font-family: 'Menlo', 'Courier New', monospace;
}

.multiplier-edit {
  font-size: 11px;
  color: #7A6B4A;
  border-left: 1px solid #3A3520;
  padding-left: 8px;
}

/* 任务区 */
.task-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 2px 0;
}

.task-title {
  font-size: 16px;
  font-weight: 600;
  color: #D4C8A0;
}

.task-add-btn {
  background: rgba(255, 176, 0, 0.15);
  border: 1px solid #FFB000;
  border-radius: 4px;
  padding: 3px 10px;
}

.task-add-btn:active {
  background: rgba(255, 176, 0, 0.3);
}

.task-add-text {
  font-size: 13px;
  color: #FFB000;
  font-weight: 600;
}

/* 空状态 */
.task-empty {
  text-align: center;
  padding: 40px 20px;
}

.task-empty-text {
  font-size: 14px;
  color: #7A6B4A;
  display: block;
}

.task-empty-hint {
  font-size: 12px;
  color: #5A4D3A;
  margin-top: 6px;
  display: block;
}

/* 任务卡片 */
.task-card {
  background: #1C1A10;
  border: 1px solid #3A3520;
  border-radius: 10px;
  padding: 14px 16px;
  margin-bottom: 10px;
  transition: border-color 200ms;
}

.task-card:active {
  border-color: #FFB000;
}

.task-done {
  opacity: 0.6;
}

.task-card-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.task-emoji {
  font-size: 18px;
}

.task-name {
  font-size: 15px;
  font-weight: 600;
  color: #D4C8A0;
  flex: 1;
}

.task-status {
  font-size: 13px;
  color: #67C23A;
  font-weight: 600;
}

.task-card-body {
  display: flex;
  gap: 20px;
  margin-bottom: 10px;
}

.task-countdown,
.task-estimate {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.countdown-label,
.estimate-label {
  font-size: 11px;
  color: #7A6B4A;
}

.countdown-value {
  font-family: 'Menlo', 'Courier New', monospace;
  font-size: 18px;
  font-weight: bold;
  color: #FFB000;
}

.estimate-value {
  font-size: 13px;
  color: #D4C8A0;
}

/* 任务操作按钮 */
.task-card-actions {
  display: flex;
  gap: 10px;
  margin-top: 4px;
}

.task-action-btn {
  flex: 1;
  background: transparent;
  border: 1px solid #3A3520;
  border-radius: 6px;
  padding: 8px 0;
  text-align: center;
}

.task-action-btn:active {
  background: rgba(255, 176, 0, 0.1);
  border-color: #FFB000;
}

.action-added {
  border-color: #67C23A;
  opacity: 0.7;
}

.action-added .action-text {
  color: #67C23A;
}

.action-text {
  font-size: 13px;
  color: #7A6B4A;
}

.action-delete .action-text {
  color: #E85D3A;
}

.action-delete {
  border-color: rgba(232, 93, 58, 0.3);
}

/* 倍率弹窗 */
.modal-hint {
  font-size: 12px;
  color: #E85D3A;
  text-align: center;
  display: block;
  margin-bottom: 12px;
}

.multiplier-input-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2D2816;
  border: 1px solid #3A3520;
  border-radius: 8px;
  padding: 8px 16px;
  margin-bottom: 16px;
}

.multiplier-modal-input {
  width: 80px;
  font-family: 'Menlo', 'Courier New', monospace;
  font-size: 22px;
  font-weight: bold;
  color: #FFB000;
  text-align: center;
  line-height: 1.2;
}

.multiplier-modal-unit {
  font-size: 18px;
  color: #7A6B4A;
  margin-left: 4px;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 280px;
  background: #1C1A10;
  border: 1px solid #3A3520;
  border-radius: 12px;
  padding: 24px 20px;
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #D4C8A0;
  text-align: center;
  display: block;
  margin-bottom: 20px;
}

/* 模板列表 */
.template-list {
  margin-bottom: 16px;
}

.template-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: #2D2816;
  border: 1px solid #3A3520;
  border-radius: 8px;
  margin-bottom: 8px;
}

.template-item:active {
  border-color: #FFB000;
  background: rgba(255, 176, 0, 0.1);
}

.template-emoji {
  font-size: 22px;
}

.template-name {
  font-size: 15px;
  font-weight: 600;
  color: #D4C8A0;
  flex: 1;
}

.template-hint {
  font-size: 12px;
  color: #7A6B4A;
}

/* 时间输入 */
.time-input-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 12px;
}

.time-input-col {
  text-align: center;
}

.time-input-label {
  font-size: 11px;
  color: #7A6B4A;
  display: block;
  margin-bottom: 6px;
}

.time-input {
  width: 64px;
  font-family: 'Menlo', 'Courier New', monospace;
  font-size: 24px;
  font-weight: bold;
  color: #FFB000;
  text-align: center;
  background: #2D2816;
  border: 1px solid #3A3520;
  border-radius: 8px;
  padding: 10px 12px;
  line-height: 1.2;
}

.time-input-sep {
  font-size: 28px;
  color: #7A6B4A;
  margin-top: 18px;
}

.time-picker-preview {
  text-align: center;
  margin-bottom: 16px;
}

.preview-label {
  font-size: 12px;
  color: #7A6B4A;
  display: block;
}

.preview-value {
  font-size: 14px;
  color: #D4C8A0;
  margin-top: 4px;
  display: block;
}

/* 弹窗按钮 */
.modal-actions {
  margin-top: 8px;
}

.modal-confirm {
  background: #FFB000;
  border-radius: 8px;
  padding: 12px 0;
  text-align: center;
}

.modal-confirm:active {
  background: #E59E00;
}

.modal-confirm-text {
  font-size: 15px;
  font-weight: 600;
  color: #121008;
}

.modal-cancel {
  padding: 12px 0;
  text-align: center;
  margin-top: 8px;
}

.modal-cancel:active .modal-cancel-text {
  color: #D4C8A0;
}

.modal-cancel-text {
  font-size: 14px;
  color: #7A6B4A;
}
